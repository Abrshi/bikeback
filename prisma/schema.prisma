model SupportTicket {
  ticket_id      Int           @id @default(autoincrement())
  user_id        Int
  ride_id        Int?
  issue_category IssueCategory
  description    String
  admin_response String?
  status         TicketStatus  @default(OPEN)

  user User  @relation(fields: [user_id], references: [user_id])
  ride Ride? @relation(fields: [ride_id], references: [ride_id])

  @@map("Support_Tickets")
}

model RatingFeedback {
  feedback_id Int     @id @default(autoincrement())
  ride_id     Int     @unique // 🔥 one feedback per ride
  rating      Int
  comment     String?
  user_id     Int

  ride Ride @relation(fields: [ride_id], references: [ride_id])
  user User @relation(fields: [user_id], references: [user_id])

  @@map("Ratings_Feedback")
}

model FidaIDVerification {
  verification_id         Int                @id @default(autoincrement())
  user_id                 Int
  id_type                 String
  id_number_hash          String
  id_document_front_url   String
  id_document_back_url    String?
  selfie_verification_url String
  verification_status     VerificationStatus @default(PENDING)
  rejection_reason        String?
  verified_at             DateTime?
  verified_by_admin_id    Int?

  user User @relation(fields: [user_id], references: [user_id])

  @@map("Fida_ID_Verifications")
}

model PricingRule {
  price_id        Int      @id @default(autoincrement())
  base_fare       Float
  rate_per_minute Float
  rate_per_km     Float
  minimum_fare    Float
  pause_rate      Float?
  penalty_fee     Float?
  currency        String
  is_active       Boolean  @default(true)
  effective_date  DateTime

  @@map("Pricing_Rules")
}

