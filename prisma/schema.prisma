generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

enum BikeStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  DISABLED
}

enum RideStatus {
  ONGOING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DiscountType {
  PERCENTAGE
}

enum IssueCategory {
  DAMAGE
  BILLING
  APP_ERROR
}

enum TicketStatus {
  OPEN
  RESOLVED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  user_id          Int           @id @default(autoincrement())
  first_name       String
  father_name      String
  grandfather_name String?
  email            String?       @unique
  password_hash    String
  phone_number     String        @unique
  account_status   AccountStatus @default(ACTIVE)
  created_at       DateTime      @default(now())

  role_id Int
  role    Role @relation(fields: [role_id], references: [role_id])

  locations     UserLocation[]
  rides         Ride[]
  payments      Payment[]
  tickets       SupportTicket[]
  feedbacks     RatingFeedback[]
  verifications FidaIDVerification[]
  sessions      Session[]

  @@map("Users")
}

model Session {
  session_id   Int      @id @default(autoincrement())
  user_id      Int
  refreshToken String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user User @relation(fields: [user_id], references: [user_id])

  @@map("Sessions")
}

model Role {
  role_id Int    @id @default(autoincrement())
  role    String @unique

  users User[]

  @@map("Role")
}

model UserLocation {
  location_id Int    @id @default(autoincrement())
  user_id     Int
  label       String
  address     String
  latitude    Float
  longitude   Float

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("User_Locations")
}

model Bike {
  bike_id            Int        @id @default(autoincrement())
  qr_code_identifier String?    @unique
  status             BikeStatus @default(AVAILABLE)
  battery_level      Float
  current_latitude   Float?
  current_longitude  Float?

  // ✅ reverse relation (no FK here)
  dock Dock?

  maintenance_logs MaintenanceLog[]
  rides            Ride[]

  @@map("Bikes")
}

model BikeStation {
  station_id          Int      @id @default(autoincrement())
  city                String?  @db.VarChar(50)
  subcity             String?  @db.VarChar(50)
  area_name           String?  @db.VarChar(50)
  latitude            Decimal? @db.Decimal(9, 6)
  longitude           Decimal? @db.Decimal(9, 6)
  address_description String?
  contact_phone       String?  @db.VarChar(20)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  docks Dock[]
}

model Dock {
  dock_id    Int @id @default(autoincrement())
  qr_code_identifier String?    @unique
  station_id Int

  dock_number Int
  is_occupied Boolean @default(false)
  bike_id     Int?    @unique // 🔥 ensures one bike per dock

  // ✅ relation owner
  bike Bike? @relation(fields: [bike_id], references: [bike_id])

  lock_status  String?   @db.VarChar(20)
  last_used_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  station BikeStation @relation(fields: [station_id], references: [station_id], onDelete: Cascade)
}

model MaintenanceLog {
  log_id            Int       @id @default(autoincrement())
  bike_id           Int
  issue_description String
  start_date        DateTime  @default(now())
  end_date          DateTime?
  technician_notes  String?

  bike Bike @relation(fields: [bike_id], references: [bike_id], onDelete: Cascade)

  @@map("Maintenance_Logs")
}

model Ride {
  ride_id        Int        @id @default(autoincrement())
  promo_code_id  Int?
  start_time     DateTime   @default(now())
  end_time       DateTime?
  start_lat      Float
  start_lng      Float
  end_lat        Float?
  end_lng        Float?
  total_distance Float?
  status         RideStatus @default(ONGOING)

  user_id Int
  bike_id Int

  user  User       @relation(fields: [user_id], references: [user_id])
  bike  Bike       @relation(fields: [bike_id], references: [bike_id])
  promo PromoCode? @relation(fields: [promo_code_id], references: [promo_id])

  payment  Payment?
  feedback RatingFeedback?
  tickets  SupportTicket[]

  @@map("Rides")
}

model Payment {
  payment_id         Int           @id @default(autoincrement())
  base_cost          Float
  discount_amount    Float?        @default(0)
  final_amount       Float
  payment_method     String
  transaction_status PaymentStatus @default(PENDING)
  processed_at       DateTime      @default(now())

  user_id  Int
  ride_id  Int  @unique // 🔥 ONE payment per ride
  promo_id Int?

  user  User       @relation(fields: [user_id], references: [user_id])
  ride  Ride       @relation(fields: [ride_id], references: [ride_id])
  promo PromoCode? @relation(fields: [promo_id], references: [promo_id])

  @@map("Payments")
}

model PromoCode {
  promo_id      Int          @id @default(autoincrement())
  code          String       @unique
  discount_type DiscountType
  value         Float
  is_active     Boolean      @default(true)
  expiry_date   DateTime

  rides    Ride[]
  payments Payment[]

  @@map("Promo_Codes")
}

